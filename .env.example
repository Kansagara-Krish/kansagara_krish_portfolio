# ──────────────────────────────────────────────────────────────────────────────
# DATABASE & INFRASTRUCTURE
# ──────────────────────────────────────────────────────────────────────────────

# Main PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:password@localhost:5432/portfolio"

# ──────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & SECURITY
# ──────────────────────────────────────────────────────────────────────────────

# Password for the admin dashboard (/login).
AUTH_ADMIN_PASSWORD="admin"

# Secret key used for signing and verifying JWT authentication tokens.
AUTH_JWT_SECRET=""

# ──────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT & SEO
# ──────────────────────────────────────────────────────────────────────────────

# The absolute base URL of your deployed application (no trailing slash).
SITE_URL="http://localhost:3000"

# Disables anonymous telemetry collection.
TELEMETRY_DISABLED=1

# ──────────────────────────────────────────────────────────────────────────────
# AI INTEGRATION
# ──────────────────────────────────────────────────────────────────────────────

# API key for the AI provider to power content generation.
AI_API_KEY=""

# The specific model ID to use (e.g., openai/gpt-oss-20b:free).
AI_MODEL="openai/gpt-oss-20b:free"

# ──────────────────────────────────────────────────────────────────────────────
# FILE STORAGE
# ──────────────────────────────────────────────────────────────────────────────

# Storage project URL.
STORAGE_URL=""

# Public anonymous key for client-side storage interactions.
STORAGE_KEY=""
