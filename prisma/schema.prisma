// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  excerpt      String
  content      String
  contentFormat String   @default("mdx")
  coverImage   String?
  published    Boolean  @default(false)
  readingTime  Int      @default(5)
  tags         Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  content       String
  subtitle      String?
  role          String?
  client        String?
  category      String?
  timeline      String?
  year          String?
  problem       String?
  solution      String?
  impact        String?
  features      Json     @default("[]")
  outcomes      Json     @default("[]")
  techStack     Json     @default("[]")
  liveUrl       String?
  githubUrl     String?
  imageUrl      String?
  galleryImages Json     @default("[]")
  projectLinks  Json     @default("[]")
  featured      Boolean  @default(false)
  status        String   @default("completed")
  tags          Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Experience {
  id          String    @id @default(cuid())
  company     String
  role        String
  location    String?
  type        String    @default("full-time")
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String
  skills      Json      @default("[]")
  logoUrl     String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Certification {
  id           String   @id @default(cuid())
  name         String
  issuer       String
  date         DateTime
  url          String?
  credentialId String?
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  category  String
  iconUrl   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hackathon {
  id          String   @id @default(cuid())
  title       String
  project     String
  role        String?
  date        DateTime
  location    String?
  result      String?
  link        String?
  description String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Settings {
  id            String   @id @default(cuid())
  name          String
  title         String
  bio           String
  email         String
  github        String?
  linkedin      String?
  twitter       String?
  resumeUrl     String?
  avatarUrl     String?
  heroTagline   String?
  openToWork    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
